# Vercel AI Gateway (recommended on Vercel — team key: aidea-co-prod, see docs/DEPLOYMENT.md)
AI_GATEWAY_API_KEY=

# Optional override; default is https://ai-gateway.vercel.sh/v1
# AI_GATEWAY_BASE_URL=

# Nango — OAuth for Gmail & Calendar (https://app.nango.dev)
NANGO_SECRET_KEY=
AIDEA_SESSION_SECRET=
AIDEA_TENANT_DERIVATION_SECRET=
# Optional integration IDs (defaults: google-mail, google-calendar)
# NANGO_GMAIL_INTEGRATION_ID=
# NANGO_CALENDAR_INTEGRATION_ID=

# Direct Anthropic (local dev fallback when AI_GATEWAY_API_KEY is unset)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Web search (Brave Search API — https://brave.com/search/api/)
BRAVE_SEARCH_API_KEY=

# Postgres (Neon, Supabase, RDS, local — any standard Postgres)
DATABASE_URL=

# Legacy/alternate env names (optional fallbacks)
POSTGRES_URL=

# Vercel KV (auto-injected on Vercel when linked — human-in-the-loop across instances)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Cron job auth (Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Single-user default (expand to multi-tenant later)
DEFAULT_USER_ID=default

# Strava — health sync OAuth (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Optional override; default is {origin}/api/integrations/strava/callback
# STRAVA_REDIRECT_URI=

# Phase 3 — add when ready
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# SLACK_BOT_TOKEN=
# NOTION_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
