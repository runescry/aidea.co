{
  "name": "aidea-co",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run lib",
    "test:contract": "vitest run app/api",
    "test:integration": "RUN_INTEGRATION=1 INTEGRATION_CHAT=1 vitest run --config vitest.integration.config.ts",
    "test:inbox-triage": "RUN_INTEGRATION=1 vitest run --config vitest.integration.config.ts tests/integration/inbox-triage.test.ts",
    "test:inbox-triage:live": "RUN_INTEGRATION=1 INTEGRATION_GMAIL=1 vitest run --config vitest.integration.config.ts tests/integration/inbox-triage.test.ts",
    "test:inbox-triage:run": "npx tsx scripts/test-inbox-triage.mts",
    "test:integration:e2e": "RUN_INTEGRATION=1 INTEGRATION_E2E=1 INTEGRATION_GMAIL=1 vitest run --config vitest.integration.config.ts tests/integration/inbox-approve-e2e.test.ts",
    "test:e2e": "RUN_INTEGRATION=1 vitest run --config vitest.integration.config.ts tests/integration/profile-memory-e2e.test.ts tests/integration/platform.test.ts",
    "test:e2e:profile": "RUN_INTEGRATION=1 vitest run --config vitest.integration.config.ts tests/integration/profile-memory-e2e.test.ts",
    "test:e2e:inbox": "npm run test:integration:e2e",
    "test:e2e:all": "RUN_INTEGRATION=1 vitest run --config vitest.integration.config.ts tests/integration/profile-memory-e2e.test.ts tests/integration/platform.test.ts && npm run test:integration:e2e",
    "reset:activity": "npx tsx scripts/reset-activity.mts",
    "seed": "npx tsx scripts/seed-sample-data.mts",
    "test:all": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@anthropic-ai/sdk": "^0.37.0",
    "@nangohq/frontend": "^0.70.8",
    "@nangohq/node": "^0.70.8",
    "@vercel/kv": "^3.0.0",
    "ai": "^4.3.16",
    "mermaid": "^11.15.0",
    "next": "^15.0.0",
    "postgres": "^3.4.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
